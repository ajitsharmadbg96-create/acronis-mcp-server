# OPTIONAL: you can leave these blank and instead set your Acronis
# credentials from the dashboard's Settings page in the browser after it's
# running (Settings link in the top bar, or /settings). Values here act as
# a fallback if the Settings page hasn't been used yet.
#
# Find your datacenter URL (e.g. https://eu2-cloud.acronis.com) in the
# Acronis Management Portal address bar after logging in.
ACRONIS_DATACENTER_URL=https://eu2-cloud.acronis.com

# Create these in Acronis Management Console -> Settings -> API Clients.
ACRONIS_CLIENT_ID=your-client-id
ACRONIS_CLIENT_SECRET=your-client-secret

PORT=3000

# Dashboard login (see: npm run create-user)
# If username/password is blank, it defaults to acronis / acronis so login
# always works out of the box. Change it once things are running, either by:
#   (a) setting DASHBOARD_PASSWORD to any plain-text password (simplest), or
#   (b) running `node scripts/create-dashboard-user.js "your-password"` and
#       pasting the resulting DASHBOARD_PASSWORD_HASH here instead.
DASHBOARD_PORT=4000
DASHBOARD_USERNAME=acronis
DASHBOARD_PASSWORD=acronis
DASHBOARD_PASSWORD_HASH=
DASHBOARD_SESSION_SECRET=change-this-to-a-random-string
